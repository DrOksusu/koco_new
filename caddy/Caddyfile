watermark-api.koco.me {
    reverse_proxy localhost:4000
}

koco.me, www.koco.me {
    # NextAuth 경로 → Next.js (session, callback, signin, signout, error, csrf, providers)
    # koco-api의 /auth/login, /auth/signup, /auth/refresh, /auth/me 와 구분
    @nextauth path /new/api/auth/session /new/api/auth/session/* /new/api/auth/callback/* /new/api/auth/signin /new/api/auth/signin/* /new/api/auth/signout /new/api/auth/signout/* /new/api/auth/error /new/api/auth/csrf /new/api/auth/providers
    handle @nextauth {
        reverse_proxy localhost:3002
    }

    # /new/api/* → koco-api Express (port 3003)
    handle /new/api/* {
        reverse_proxy localhost:3003
    }

    # /new/* -> Next.js Docker (port 3002) — 페이지만
    handle /new/* {
        reverse_proxy localhost:3002
    }
    handle /new {
        reverse_proxy localhost:3002
    }

    # /api/* -> koco-api (uri rewrite 후 전달)
    handle /api/landmark/* {
        uri replace /api/ /new/api/
        reverse_proxy localhost:3003
    }
    handle /api/upload/* {
        uri replace /api/ /new/api/
        reverse_proxy localhost:3003
    }
    handle /api/s3/* {
        uri replace /api/ /new/api/
        reverse_proxy localhost:3003
    }
    handle /api/psa/* {
        uri replace /api/ /new/api/
        reverse_proxy localhost:3003
    }
    handle /api/pso/* {
        uri replace /api/ /new/api/
        reverse_proxy localhost:3003
    }

    # Page redirects to /new prefix
    @pages path /dashboard* /history* /psa* /pso* /landmark* /auth*
    redir @pages /new{uri} permanent

    # /blog -> Django (port 8000)
    handle /blog/* {
        reverse_proxy localhost:8000
    }

    # Default -> Flask (port 9500)
    handle {
        reverse_proxy localhost:9500
    }
}
