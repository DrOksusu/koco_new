watermark-api.koco.me {
    reverse_proxy localhost:4000
}

koco.me, www.koco.me {
    # ── API 라우팅 ──

    # NextAuth → Next.js (OAuth callback, session 등)
    @nextauth path /new/api/auth/session* /new/api/auth/callback* /new/api/auth/signin* /new/api/auth/signout* /new/api/auth/error /new/api/auth/csrf /new/api/auth/providers
    handle @nextauth {
        reverse_proxy localhost:3002
    }

    # /new/api/* → koco-api
    handle /new/api/* {
        reverse_proxy localhost:3003
    }

    # /api/* → rewrite → koco-api (레거시 호환)
    handle /api/* {
        uri replace /api/ /new/api/
        reverse_proxy localhost:3003
    }

    # ── 페이지 라우팅 ──

    # /new/* → Next.js
    handle /new/* {
        reverse_proxy localhost:3002
    }
    handle /new {
        reverse_proxy localhost:3002
    }

    # 짧은 경로 → /new 리다이렉트
    @pages path /dashboard* /history* /psa* /pso* /landmark* /auth*
    redir @pages /new{uri} permanent

    # /blog → Django
    handle /blog/* {
        reverse_proxy localhost:8000
    }

    # 기본 → Flask
    handle {
        reverse_proxy localhost:9500
    }
}
